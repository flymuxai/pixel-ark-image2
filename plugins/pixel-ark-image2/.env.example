# Required. You can also use OPENAI_API_KEY.
IMAGE2_API_KEY=

# Optional. Defaults to https://api.flymux.com.
IMAGE2_BASE_URL=https://api.flymux.com

# Optional. Defaults to gpt-image-2.
IMAGE2_MODEL=gpt-image-2

# Optional. Defaults to ./assets inside this MCP server directory.
IMAGE2_DEFAULT_OUTPUT_DIR=~/.codex/mcp/image2/assets

# Optional. Used only by element extraction fallback on Windows or custom Python installs.
# IMAGE2_PYTHON=python
