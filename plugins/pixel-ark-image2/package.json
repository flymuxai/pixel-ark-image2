{
  "name": "pixel-ark-image2",
  "version": "0.1.0",
  "description": "A local GPT Image2 MCP server for generating, editing, and exporting image assets.",
  "private": true,
  "type": "module",
  "bin": {
    "pixel-ark-image2": "./dist/server.js",
    "pixel-ark-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "esbuild server.js --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.js",
    "start": "node server.js"
  },
  "keywords": [
    "mcp",
    "gpt-image-2",
    "image-generation",
    "codex"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "esbuild": "^0.27.2"
  },
  "engines": {
    "node": ">=20"
  }
}
